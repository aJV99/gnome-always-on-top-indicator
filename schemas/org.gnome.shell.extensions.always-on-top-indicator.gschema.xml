<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.always-on-top-indicator" path="/org/gnome/shell/extensions/always-on-top-indicator/">
    <key name="border-thickness" type="d">
      <default>1.0</default>
      <summary>Border thickness</summary>
      <description>Thickness of the border around always-on-top windows (in pixels)</description>
      <range min="0.25" max="10.0"/>
    </key>
    <key name="border-color" type="s">
      <default>'#bd93f9'</default>
      <summary>Border color</summary>
      <description>Border color in hex format (#rrggbb).</description>
    </key>
    <key name="border-opacity" type="d">
      <default>1.0</default>
      <summary>Border opacity</summary>
      <description>Border opacity from 0.0 (transparent) to 1.0 (fully opaque).</description>
      <range min="0.0" max="1.0"/>
    </key>
    <key name="corner-radius" type="d">
      <default>0.0</default>
      <summary>Corner radius</summary>
      <description>Corner radius of the border in pixels.</description>
      <range min="0.0" max="20.0"/>
    </key>
  </schema>
</schemalist>
